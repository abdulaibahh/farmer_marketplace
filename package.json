{
  "name": "farmer-market-place",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start",
    "android": "node ./node_modules/expo/bin/cli start --android",
    "ios": "node ./node_modules/expo/bin/cli start --ios",
    "web": "node ./node_modules/expo/bin/cli start --web",
    "export:web": "node ./node_modules/expo/bin/cli export -p web --output-dir dist",
    "api": "node ./backend/src/index.js",
    "build:android:apk": "npx eas build -p android --profile preview",
    "build:android:aab": "npx eas build -p android --profile production",
    "build:ios": "npx eas build -p ios --profile production",
    "submit:android": "npx eas submit -p android --profile production",
    "submit:ios": "npx eas submit -p ios --profile production"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "babel-preset-expo": "~54.0.11"
  }
}
